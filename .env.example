# ─── Core ────────────────────────────────────────────────────
# PORT is the HOST-side port docker-compose publishes (host PORT → container
# 7778). The server binds 7778 inside the container (LAZY_TOOL_SERVICE_PORT
# overrides the bind). External callers must use http://<host>:5591.
PORT=5591
LAZY_TOOL_SERVICE_API_KEY=<YOUR_API_KEY>
NODE_ENV=production

# ─── Required in practice (hydrated from vault-service at boot when
#     available; set explicitly when running without vault) ─────────
# MONGO_URI=mongodb://<YOUR_NAS_IP>:27017        # hard dependency at startup
# TOOLS_SERVICE_URL=http://<YOUR_NAS_IP>:5590    # GitWorktreeHelper breaks if unset
# REAL_PRISM_URL=http://<YOUR_NAS_IP>:7777       # prism-proxy upstream target

# ─── CORS (optional — comma-separated additional origins) ───
# CORS_ORIGINS=http://192.168.1.100:3000,http://custom-domain:8888

# ─── Python Execution ──────────────────────────────────────
# PYTHON_INTERPRETER=/opt/venv/bin/python
# PYTHON_EXEC_SCRIPT=/app/python/scripts/execute_tool.py
# PYTHON_CWD=/app/python
# PYTHONPATH=/app/python
# EXECUTION_TIMEOUT_MS=30000

# ─── Trading Service ──────────────────────────────────────
TRADING_SERVICE_URL=http://<YOUR_NAS_IP>:3031
TRADING_SERVICE_API_KEY=<YOUR_TRADING_SERVICE_API_KEY>

# ─── MongoDB (optional) ──────────────────────────────────
# MONGO_URI=mongodb://<MONGO_USER>:<MONGO_PASS>@<YOUR_NAS_IP>:27017/?directConnection=true&authSource=admin

# ─── Cache ───────────────────────────────────────────────
# CACHE_TTL_MS=60000

# ─── HTML Notes ──────────────────────────────────────────────
HTML_NOTES_URL=http://<YOUR_NAS_IP>:8035

# ─── Service URL ─────────────────────────────────────────────
LAZY_TOOL_SERVICE_URL=http://localhost:5591
