[
  {
    "name": "create_widget",
    "description": "Create a new visual widget on the canvas dashboard grid. Standard widget types: checklist, clock, notes, iframe_app, mini_music_player, youtube_player, custom.",
    "parameters": {
      "type": "object",
      "properties": {
        "widgetType": {
          "type": "string",
          "enum": [
            "checklist",
            "clock",
            "notes",
            "iframe_app",
            "mini_music_player",
            "youtube_player",
            "custom"
          ]
        },
        "title": {
          "type": "string"
        },
        "htmlContent": {
          "type": "string",
          "description": "Raw HTML for the widget interface"
        },
        "cssContent": {
          "type": "string",
          "description": "Widget-specific styling. Will be isolated to the widget container."
        },
        "jsContent": {
          "type": "string",
          "description": "Widget-specific scripting. Avoid globally scoped assignments."
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "CDN script or stylesheet URLs"
        },
        "renderTarget": {
          "type": "string",
          "description": "CSS selector to append the widget to, e.g. #dashboard-grid"
        }
      },
      "required": [
        "widgetType",
        "title",
        "htmlContent"
      ]
    },
    "tier": 1,
    "source": "canvas_manager",
    "permission": "write",
    "fallback_only": false,
    "concurrency_safe": true,
    "max_result_chars": 50000,
